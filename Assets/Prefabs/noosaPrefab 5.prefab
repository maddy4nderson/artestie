  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'This is a recreation of the road I used to live on in Noosa, Queensland.
    I only spent six months there, but it felt like everything fell into place. Living
    with friends, working by the beach, and just enjoying the everyday moments made
    it one of the happiest times in my life.


    It means so much to me because
    it reminds me of how free and content I felt, like I was exactly where I was
    meant to be. Now living in Bristol, life feels more fast-paced and structured,
    which makes those memories stand out even more.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
